---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags || []) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="태그" sideBarActiveItemID="tags">
  <div class="mb-4 border-b border-base-300 pb-4">
    <h1 class="text-3xl font-bold">🏷️ 태그</h1>
    <p class="opacity-70 mt-1">총 {tags.length}개의 태그</p>
  </div>

  {
    tags.length === 0 ? (
      <p class="opacity-70 mt-4">아직 태그가 없습니다.</p>
    ) : (
      <div class="flex flex-wrap gap-2 mt-4">
        {tags.map(([tag, count]) => (
          <a href={`/blog/tag/${tag}`} class="badge badge-lg badge-outline hover:badge-primary py-3">
            #{tag} <span class="opacity-60 ml-1">{count}</span>
          </a>
        ))}
      </div>
    )
  }
</BaseLayout>
