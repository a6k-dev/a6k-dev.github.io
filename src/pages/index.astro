---
import BaseLayout from "../layouts/BaseLayout.astro";
import PostListItem from "../components/PostListItem.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";
import { PROFILE, CATEGORIES } from "../config";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const last_posts = posts.slice(0, 5);
---

<BaseLayout sideBarActiveItemID="home">
  <section class="pb-8 mt-4 border-b border-base-300">
    <div class="text-lg opacity-70">안녕하세요 👋</div>
    <h1 class="text-4xl md:text-5xl font-bold mt-2">{PROFILE.name} 의 데이터 · AI 블로그</h1>
    <p class="py-4 text-lg leading-relaxed opacity-80">
      데이터 엔지니어링과 AI를 공부하며 배운 것들을 정리합니다.
      데이터 파이프라인, MLOps, LLM 그리고 그 사이의 모든 것에 대한 기록입니다.
    </p>
    <div class="mt-2 flex flex-wrap gap-2">
      <a class="btn btn-sm btn-primary" href="/blog/">전체 글 보기</a>
      <a class="btn btn-sm btn-outline" href="/about">About</a>
    </div>
  </section>

  <section class="mt-8">
    <h2 class="text-2xl font-bold mb-2">카테고리</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-4">
      {
        CATEGORIES.map((cat) => (
          <a
            href={`/blog/category/${cat.slug}`}
            class="card bg-base-200 hover:bg-base-300 transition-colors p-4"
          >
            <div class="text-lg font-bold">
              {cat.icon} {cat.label}
            </div>
            <div class="text-sm opacity-70 mt-1">{cat.description}</div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="mt-10">
    <div class="flex items-end justify-between">
      <h2 class="text-2xl font-bold">최근 글</h2>
      <a href="/blog/" class="text-sm text-primary hover:underline">더보기 →</a>
    </div>
    <div class="divide-y divide-base-300 mt-2">
      {
        last_posts.length === 0 ? (
          <p class="py-8 opacity-70">아직 작성된 글이 없습니다.</p>
        ) : (
          last_posts.map((post) => (
            <PostListItem
              title={post.data.title}
              desc={post.data.description}
              url={"/blog/" + createSlug(post.data.title, post.slug)}
              pubDate={post.data.pubDate}
              category={post.data.category}
              tags={post.data.tags}
              badge={post.data.badge}
            />
          ))
        )
      }
    </div>
  </section>
</BaseLayout>
