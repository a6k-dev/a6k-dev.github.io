---
import { CATEGORIES } from "../config";
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-base-300 font-semibold";
---

<ul class="menu grow shrink menu-md overflow-y-auto px-1">
  <li>
    <a class="py-3 text-base" id="home" href="/">
      <span class="w-5 text-center">🏠</span> Home
    </a>
  </li>
  <li>
    <a class="py-3 text-base" id="blog" href="/blog/">
      <span class="w-5 text-center">📚</span> 전체 글
    </a>
  </li>

  <li class="menu-title mt-2 text-xs uppercase tracking-wider opacity-60">Categories</li>
  {
    CATEGORIES.map((cat) => (
      <li>
        <a class="py-3 text-base" id={`cat-${cat.slug}`} href={`/blog/category/${cat.slug}`}>
          <span class="w-5 text-center">{cat.icon}</span> {cat.label}
        </a>
      </li>
    ))
  }

  <li class="menu-title mt-2 text-xs uppercase tracking-wider opacity-60">More</li>
  <li>
    <a class="py-3 text-base" id="tags" href="/tags">
      <span class="w-5 text-center">🏷️</span> 태그
    </a>
  </li>
  <li>
    <a class="py-3 text-base" id="about" href="/about">
      <span class="w-5 text-center">👋</span> About
    </a>
  </li>
</ul>

<script define:vars={{ sideBarActiveItemID, activeClass }}>
  const activeItemElem = document.getElementById(sideBarActiveItemID);
  activeItemElem && activeItemElem.classList.add(...activeClass.split(" "));
</script>
